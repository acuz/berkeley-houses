rules_version = '2';

// Berkeley House Search — locked to the two known accounts.
// Even though the web API key is public (by design), nobody else can read or
// write: access requires being signed in AS one of these two UIDs, so a
// self-registered stranger account is rejected.
service cloud.firestore {
  match /databases/{database}/documents {

    function isUs() {
      return request.auth != null && request.auth.uid in [
        "ewRt7NBEmtaCLKhAvtPuNmwPsC82",  // angelo.cuzzola@gmail.com
        "1xdx8P6hoDTVE1udIHMUdSGXKwq1"   // irene.nicolino@gmail.com
      ];
    }

    match /houses/{houseId} {
      allow read, write: if isUs();
      match /interactions/{intId} {
        allow read, write: if isUs();
      }
    }
  }
}
